# IFRS AI Frontend Environment Variables
# Copy this file to .env.local and fill in your values

# Supabase Configuration (Optional - for authentication)
# If not configured, the app will run in demo mode
# Get credentials from: https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Backend API URL
# Local dev: leave unset — Next proxies using api_dev_port.txt (written by python app.py) or port 9000
# Or set explicitly: NEXT_PUBLIC_API_URL=http://127.0.0.1:9001
# Or port only (server proxy reads this): BACKEND_PORT=9001
#
# Vercel (recommended): leave NEXT_PUBLIC_API_URL empty so the browser calls /api/* on your Vercel domain.
# Set BACKEND_URL (server-only) to your deployed Python base, e.g. https://your-api.onrender.com — no trailing slash.
# BACKEND_URL=
#
# Production (browser calls Python directly; enable CORS on Python): NEXT_PUBLIC_API_URL=https://your-api.example.com
# NEXT_PUBLIC_API_URL=
# BACKEND_PORT=

# Customer-facing deployments (next build / production): shown when the API is unreachable
# NEXT_PUBLIC_SUPPORT_CONTACT=your IT helpdesk or support@company.com

# Anthropic (server-only) — used by /api/cfo-strategic-insights for CFO Insights page.
# Do not use NEXT_PUBLIC_*; the key stays on the server.
# ANTHROPIC_API_KEY=
