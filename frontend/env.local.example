# IFRS AI Frontend Environment Variables
# Copy this file to .env.local and fill in your values

# Supabase Configuration (Optional - for authentication)
# If not configured, the app will run in demo mode
# Get credentials from: https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Backend API URL (Required)
# Local: http://localhost:9000  |  Production: https://ifrsai.onrender.com
NEXT_PUBLIC_API_URL=http://localhost:9000
