# IFRS AI Backend Environment Variables
# Copy this file to .env and fill in your values

# Claude API Key (Required for contract extraction and RAG)
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Optional: Database Configuration (if using PostgreSQL)
# DATABASE_URL=postgresql://user:password@localhost:5432/ifrsai

# Optional: ChromaDB Persistence Directory
# CHROMA_PERSIST_DIR=./chroma_db

# Health Monitor Email Alerts (optional)
# For Gmail: use App Password from Google Account → Security → 2-Step Verification → App Passwords
# ALERT_EMAIL_FROM=your-gmail@gmail.com
# ALERT_EMAIL_PASSWORD=your-gmail-app-password
# ALERT_EMAIL_TO=manasa@gnanova.pro
